# ─────────────────────────────────────────────────────────────────
#  QUANT CLUB WEBSITE — ENVIRONMENT VARIABLES
#
#  Copy this file to .env.local and fill in your values.
#  .env.local is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────

# ── Google Calendar Integration ───────────────────────────────────
# Steps to get these:
#   1. Create a public Google Calendar (Settings → Make available to public)
#   2. Copy the Calendar ID from Settings → Integrate calendar
#   3. Go to console.cloud.google.com → Enable "Google Calendar API"
#      → Create an API Key → restrict it to Calendar API only
#   4. Paste both values below, then restart the dev server.
#
# Once set, ANY event you add in Google Calendar will appear on
# the website automatically (refreshed every 5 minutes).

NEXT_PUBLIC_GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
NEXT_PUBLIC_GOOGLE_CALENDAR_API_KEY=AIza...your-api-key-here
